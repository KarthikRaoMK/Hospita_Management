# Step 1: Build the React frontend and Spring Boot backend together
FROM maven:3.9.6-eclipse-temurin-21 AS build
WORKDIR /app

# Copy the pom.xml and the entire source code
COPY pom.xml .
COPY src ./src
COPY frontend ./frontend

# Run the maven build (this triggers your frontend plugin automatically!)
RUN mvn clean package -DskipTests

# Step 2: Create a minimal runtime environment to run the JAR
FROM eclipse-temurin:21-jre-jammy
WORKDIR /app

# Copy the built JAR file from the first step
COPY --from=build /app/target/*.jar app.jar

# Expose the cloud assigned port and start the app
EXPOSE 8080
ENTRYPOINT ["java", "-jar", "app.jar"]